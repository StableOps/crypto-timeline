---
import '../styles/global.css'
import Timeline from '../components/Timeline.astro'
---

<Timeline locale="en" />

<script>
;(function(){
  if (document.cookie.includes('lang_pref=')) return
  const lang = navigator.language || ''
  if (lang.startsWith('zh')) {
    document.cookie = 'lang_pref=zh; path=/; max-age=86400'
    location.href = '/zh/'
  }
})()
</script>
